# 环境配置模板
# 复制为 .env 后修改

# 服务
PORT=3001
NODE_ENV=production

# JWT 密钥（务必修改）
JWT_SECRET=your-super-secret-key-here

# 数据库（可选，默认 SQLite）
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=delta_escort

# Redis 缓存（可选）
# REDIS_URL=redis://localhost:6379

# 短信服务
SMS_ENABLED=0
SMS_PROVIDER=mock
# ALIYUN_ACCESS_KEY=
# ALIYUN_SECRET_KEY=
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=

# 文件上传
UPLOAD_PROVIDER=local
# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_BUCKET=
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=ap-guangzhou

# 微信支付（上线时配置）
# WECHAT_APP_ID=
# WECHAT_MCH_ID=
# WECHAT_API_KEY=
# WECHAT_CERT_PATH=./cert/apiclient_cert.pem
# WECHAT_KEY_PATH=./cert/apiclient_key.pem
